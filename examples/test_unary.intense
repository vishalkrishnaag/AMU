# Test: ABS and NEG instructions
# Run: ./intense.out examples/test_unary.intense main

main:
    CALL test_abs
    CALL test_neg
    RET

test_abs:
    SEEK 0
    SET -42
    ABS
    PRINT             # → 42

    SEEK 1
    SET 42
    ABS
    PRINT             # → 42

    SEEK 2
    SET -3.14
    ABS
    PRINT             # → 3.14

    SEEK 3
    SET 0
    ABS
    PRINT             # → 0
    RET

test_neg:
    SEEK 0
    SET 42
    NEG
    PRINT             # → -42

    SEEK 1
    SET -10
    NEG
    PRINT             # → 10

    SEEK 2
    SET 3.5
    NEG
    PRINT             # → -3.5
    RET

# DB memory CRUD test.
#
# Edit the connection string below to match your local PostgreSQL role/database.
# This exercises:
# - DBEXEC raw SQL
# - DBINSERT from current map cell
# - DBUPDATE from @cell map
# - DBSELECT table + WHERE
# - DBDELETE table + WHERE
#
# Run:
#   ./intense.out examples/test_db_memory_crud.in10s main 4

main:
    SEEK 0
    SET "host=localhost port=5432 dbname=intense user=intense password=intense"
    DBCONNECT @0
    PRINTJ

    DBEXEC "CREATE TABLE IF NOT EXISTS poet_memory_test (memory_key text PRIMARY KEY, memory_value jsonb NOT NULL, route text, updated_at timestamptz NOT NULL DEFAULT now())"
    PRINTJ

    DBDELETE "poet_memory_test" "memory_key = 'cat_legs'"
    PRINTJ

    SET {"memory_key":"cat_legs","memory_value":{"subject":"cat","relation":"legs","answer":4},"route":"fact_lookup"}
    DBINSERT "poet_memory_test"
    PRINTJ

    SEEK 1
    SET {"memory_value":{"subject":"cat","relation":"legs","answer":4,"confidence":"high"},"route":"fact_lookup_confirmed"}
    DBUPDATE "poet_memory_test" "memory_key = 'cat_legs'" @1
    PRINTJ

    DBSELECT "poet_memory_test" "memory_key = 'cat_legs'"
    PRINTJ

    DBDELETE "poet_memory_test" "memory_key = 'cat_legs'"
    PRINTJ

    DBCLOSE
    PRINTJ
    RET

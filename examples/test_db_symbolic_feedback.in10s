# Test: symbolic contradiction and feedback update
#
# This uses logic_weight as logic/state, not as a numeric vector.
# Run:
#   ./intense.out examples/test_db_symbolic_feedback.in10s main 4

main:
    SET "host=localhost port=5432 dbname=AMU user=postgres password=postgres"
    DBCONNECT
    PRINTJ

    READFILE "training/common_memory/postgres_schema.sql"
    DBEXEC
    PRINTJ

    DBEXEC "DELETE FROM logic_feedback WHERE edge_id IN (SELECT id FROM logic_edges WHERE source_key = 'cat' AND relation = 'legs_count')"
    PRINTJ
    DBDELETE "logic_contradictions" "subject_key = 'cat' AND relation = 'legs_count'"
    PRINTJ
    DBDELETE "logic_edges" "source_key = 'cat' AND relation = 'legs_count'"
    PRINTJ
    DBDELETE "logic_nodes" "node_key IN ('cat','count_4','count_3')"
    PRINTJ

    SET {"node_key":"cat","kind":"entity","payload":{"name":"cat","class":"animal"},"confidence":0.95}
    DBINSERT "logic_nodes"
    PRINTJ

    SET {"node_key":"count_4","kind":"quantity","payload":{"value":"4","number":4},"confidence":0.98}
    DBINSERT "logic_nodes"
    PRINTJ

    SET {"node_key":"count_3","kind":"quantity","payload":{"value":"3","number":3},"confidence":0.3}
    DBINSERT "logic_nodes"
    PRINTJ

    SET {"source_key":"cat","relation":"legs_count","target_key":"count_4","logic_weight":{"state":"confirmed","support":"training_example","scope":"normal_case"},"evidence":{"text":"cat has 4 legs"},"generated_logic":"SET 4"}
    DBINSERT "logic_edges"
    PRINTJ

    SET {"source_key":"cat","relation":"legs_count","target_key":"count_3","logic_weight":{"state":"assumed","support":"unverified_user_input","scope":"unknown"},"evidence":{"text":"cat has 3 legs"},"generated_logic":"SET 3"}
    DBINSERT "logic_edges"
    PRINTJ

    DBEXEC "INSERT INTO logic_contradictions (subject_key, relation, edge_a, edge_b, conflict, resolution_state) SELECT 'cat', 'legs_count', a.id, b.id, '{\"reason\":\"same subject and relation produced different targets\"}'::jsonb, 'unresolved' FROM logic_edges a JOIN logic_edges b ON a.source_key = b.source_key AND a.relation = b.relation AND a.target_key <> b.target_key WHERE a.source_key = 'cat' AND a.relation = 'legs_count' AND a.target_key = 'count_4' AND b.target_key = 'count_3'"
    PRINTJ

    DBEXEC "INSERT INTO logic_feedback (edge_id, feedback, previous_logic_weight, new_logic_weight, reason, source) SELECT id, 'reject', logic_weight, '{\"state\":\"disputed\",\"support\":\"contradicted_by_training\",\"scope\":\"blocked\"}'::jsonb, 'training says normal cat legs_count is 4', 'trainer' FROM logic_edges WHERE source_key = 'cat' AND relation = 'legs_count' AND target_key = 'count_3'"
    PRINTJ

    SET {"logic_weight":{"state":"disputed","support":"contradicted_by_training","scope":"blocked"},"validity":"inactive"}
    DBUPDATE "logic_edges" "source_key = 'cat' AND relation = 'legs_count' AND target_key = 'count_3'"
    PRINTJ

    DBQUERY "SELECT target.payload->>'value' AS answer, e.generated_logic, e.logic_weight::text AS logic_weight, e.validity FROM logic_edges e JOIN logic_nodes target ON target.node_key = e.target_key WHERE e.source_key = 'cat' AND e.relation = 'legs_count' ORDER BY CASE e.validity WHEN 'active' THEN 1 ELSE 2 END, CASE e.logic_weight->>'state' WHEN 'preferred' THEN 1 WHEN 'confirmed' THEN 2 WHEN 'assumed' THEN 3 WHEN 'weak_assumption' THEN 4 WHEN 'disputed' THEN 5 ELSE 6 END"
    PRINTJ

    DBQUERY "SELECT subject_key, relation, resolution_state, conflict::text FROM logic_contradictions WHERE subject_key = 'cat' AND relation = 'legs_count'"
    PRINTJ

    DBCLOSE
    PRINTJ
    RET

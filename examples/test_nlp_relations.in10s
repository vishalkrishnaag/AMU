# Test: generic symbolic entity/relation extraction
# Run: ./intense.out examples/test_nlp_relations.in10s main 4

main:
    CALL test_question_fact_lookup
    CALL test_observed_fact
    CALL test_arithmetic_route
    CALL test_reverse_route
    RET

test_question_fact_lookup:
    SET "how many legs does a cat have"
    NLPRELATIONS
    PRINTJ
    RET

test_observed_fact:
    SET "human have only 2 legs"
    NLPRELATIONS
    PRINTJ
    RET

test_arithmetic_route:
    SET "what is 8 plus 9"
    NLPRELATIONS
    PRINTJ
    RET

test_reverse_route:
    SET "reverse the word poet"
    NLPRELATIONS
    PRINTJ
    RET

# Test: tape cells can store and execute quoted function bodies.
# Run: ./intense.out examples/test_tape_modules.in10s main 4

def file_directory_body
SET "module directory"
PRINT
RET
end

def patched_file_directory_body
SET "patched directory"
PRINT
RET
end

def math_answer_body
SET 40
ADD 2
PRINT
RET
end

def countdown_body
SEEK 0
SET 3
$countdown_loop:
PRINT
SUB 1
JMPIF $countdown_loop
RET
end

def main
TAPE 1
TAPE_NAME file_tape
SEEK 10
QUOTE_FUNCTION file_directory_body
SEEK 0
CALL @10

# Update the tape cell by replacing the whole quoted body.
TAPE file_tape
SEEK 10
QUOTE_FUNCTION patched_file_directory_body
SEEK 0
CALL @10

# Named tapes still make purpose-specific tapes easy to find.
TAPE 2
TAPE_NAME math_tape
SEEK 20
QUOTE_FUNCTION math_answer_body
SEEK 0
CALL @20

# Copy quoted code into a normal cell and call through that cell.
TAPE file_tape
SEEK 0
SET @10
CALL @0

# Patch one instruction inside the tape-resident function body.
TAPE file_tape
SEEK 11
SET ["SET","modified by CODESET"]
SEEK 10
CODESET 0 11
SEEK 0
CALL @10

# Quoted def bodies preserve local labels for tape-resident loops.
TAPE 3
TAPE_NAME loop_tape
SEEK 30
QUOTE_FUNCTION countdown_body
SEEK 0
CALL @30

RET
end

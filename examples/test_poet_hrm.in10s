# Test: Poet-HRM scaffolding with incognito worksheet, search, rational evidence,
# and hormone field drift.
# Run: ./intense.out examples/test_poet_hrm.in10s main 6

def main
# Seed a few explicit memory / algorithm cells.
TAPE 1
TAPE_NAME memory_tape
SEEK 0
SET "quadratic formula solves ax^2 + bx + c = 0 when factoring is not obvious"
SEEK 1
SET "story endings can be tragic, redemptive, ambiguous, or comic"
SEEK 2
SET "boolean comparison is enough for simple greater less equal questions"

TAPE 0
SEEK 0
SET "Solve x^2 + 5x + 6 = 0"
POET_STRATEGY
PRINTJ

WORKSHEET_BEGIN problem_sheet
SEEK 0
SET "Solve x^2 + 5x + 6 = 0"
SEEK 1
POET_SEARCH @0 3
PRINTJ
SEEK 2
SET 0.72
RATIONAL_RUN fuzzy
PRINTJ
WORKSHEET_END

WORKSHEET_STATE
PRINTJ
CALL auto_cleanup_demo
WORKSHEET_STATE
PRINTJ

TAPE 2
EMO_INIT emotional_tape
HORMONE curiosity
    hormone_level 80
    hormone_nature curiosity
    hormone_min 0
    hormone_max 100
    hormone_baseline 20
    hormone_decay 0.5
    hormone_sensitivity 1
    hormone_weight 1
end
EMO_FIELD
PRINTJ
EMO_TICK 1
HORMONE_LEVEL curiosity
PRINT
EMO_FIELD
PRINTJ

RET
end

def auto_cleanup_demo
WORKSHEET_BEGIN auto_sheet
SEEK 0
SET "temporary thought should vanish on RET"
RET
end

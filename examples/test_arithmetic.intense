# Test: Arithmetic operations, type promotion, and edge cases
# Run: ./intense.out examples/test_arithmetic.intense main

main:
    CALL test_int_arith
    CALL test_float_arith
    CALL test_mixed_promotion
    CALL test_mod
    CALL test_div_zero
    RET

# ---- Integer arithmetic ----
test_int_arith:
    SET 10
    ADD 5
    PRINT          # → 15

    SET 10
    SUB 3
    PRINT          # → 7

    SET 6
    MUL 7
    PRINT          # → 42

    SET 20
    DIV 4
    PRINT          # → 5  (int / int stays int)
    RET

# ---- Float arithmetic ----
test_float_arith:
    SET 1.5
    ADD 2.5
    PRINT          # → 4

    SET 5.0
    SUB 1.5
    PRINT          # → 3.5

    SET 2.5
    MUL 4.0
    PRINT          # → 10

    SET 7.0
    DIV 2.0
    PRINT          # → 3.5
    RET

# ---- Mixed promotes to float ----
test_mixed_promotion:
    SET 7
    ADD 0.5
    TYPE
    PRINT          # → float  then  7.5
    SET 7
    ADD 0.5
    PRINT          # → 7.5
    RET

# ---- MOD ----
test_mod:
    SET 17
    MOD 5
    PRINT          # → 2

    SET 100
    MOD 7
    PRINT          # → 2
    RET

# ---- DIV by zero triggers error (comment out to skip) ----
# test_div_zero:
#     SET 1
#     DIV 0
#     PRINT
#     RET

test_div_zero:
    # Placeholder — actual div-by-zero would throw; just confirm normal flow
    SET 42
    PRINT          # → 42
    RET

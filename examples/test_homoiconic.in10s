# Test: homoiconic features — EXEC, EVAL, QUOTE, MATCH, APPEND, CODE*
# Run: ./intense.out examples/test_homoiconic.intense main

main:
    CALL test_exec
    CALL test_eval_str
    CALL test_quote
    CALL test_match_types
    CALL test_match_structure
    CALL test_code_manipulation
    CALL test_dynamic_generation
    CALL test_tape_order_code_and_data
    CALL test_code_injection_with_call
    CALL test_self_modify_across_cells
    CALL test_try_catch_code_block
    RET

# ---- EXEC: execute a Code cell in place ----
test_exec:
    SEEK 0
    SET (SET 99 ; PRINT)
    EXEC              # → 99
    RET

# ---- EVAL: alias for EXEC, also works on Str cells ----
test_eval_str:
    SEEK 0
    # EVAL on a Code cell — identical to EXEC
    SET (SET 88 ; PRINT)
    EVAL              # → 88

    # EVAL on a Str cell: parses and executes the string as a single instruction
    MOVE 1
    SET "PRINT"       # cell 1 = string "PRINT"
    EVAL              # executes PRINT → prints "PRINT"
    RET

# ---- QUOTE: store instruction(s) as Code without executing ----
test_quote:
    SEEK 0
    # Single instruction form
    QUOTE PRINT
    TYPE
    PRINT             # → code

    # Code block form
    QUOTE (SET 7 ; PRINT)
    EXEC              # → 7

    # CODELEN on a quoted block
    QUOTE (ADD 1 ; MUL 2 ; PRINT)
    CODELEN
    PRINT             # → 3
    RET

# ---- MATCH: type-based pattern matching ----
test_match_types:
    SEEK 0
    SET 42
    MATCH int
    PRINT             # → true

    MOVE 1
    SET 3.14
    MATCH float
    PRINT             # → true

    MOVE 1
    SET "hello"
    MATCH str
    PRINT             # → true

    MOVE 1
    SET true
    MATCH bool
    PRINT             # → true

    MOVE 1
    SET null
    MATCH nil
    PRINT             # → true

    # Wildcard _ matches anything
    MOVE 1
    SET 99
    MATCH _
    PRINT             # → true

    # Wrong type → false
    MOVE 1
    SET 42
    MATCH str
    PRINT             # → false
    RET

# ---- MATCH: structural pattern matching ----
test_match_structure:
    SEEK 0
    SET [1, 2, 3]
    MATCH [_, _, _]
    PRINT             # → true (any list of 3)

    MOVE 1
    SET [1, 2, 3]
    MATCH [_, 2, _]
    PRINT             # → true (middle element == 2)

    MOVE 1
    SET [1, 2, 3]
    MATCH [_, 9, _]
    PRINT             # → false (middle element != 9)

    MOVE 1
    SET 42
    MATCH 42
    PRINT             # → true

    MOVE 1
    SET 42
    MATCH 43
    PRINT             # → false
    RET

# ---- Code manipulation: CODEGET, CODESET, CODEAPPEND, CODELEN ----
test_code_manipulation:
    SEEK 0
    # CODEGET: extract instruction as list
    SET (SET 5 ; PRINT)
    CODEGET 0
    PRINT             # → [SET,5]

    # CODELEN
    SET (SET 5 ; PRINT)
    CODELEN
    PRINT             # → 2

    # CODEAPPEND: append instruction from another cell
    SET (SET 5)
    MOVE 1
    SET ["PRINT"]
    BACK 1
    CODEAPPEND 1      # append PRINT to Code block at cell 0
    EXEC              # → 5

    # CODESET: replace an instruction
    SEEK 0
    SET (SET 5 ; PRINT)
    MOVE 1
    SET ["SET", "99"]
    BACK 1
    CODESET 0 1       # replace instruction[0] with SET 99
    EXEC              # → 99
    RET

# ---- Dynamic code generation: build and execute a block at runtime ----
test_dynamic_generation:
    SEEK 0
    # Build a block dynamically from scratch
    SET ()
    APPEND ["SET", "42"]
    APPEND ["PRINT"]
    EXEC              # → 42

    # Patch an existing block before executing
    SEEK 0
    SET (SET 100 ; PRINT)
    MOVE 1
    SET ["SET", "777"]
    BACK 1
    CODESET 0 1       # patch SET 100 → SET 777
    EXEC              # → 777
    RET

# ---- Tape order: code and data coexist in navigable cells ------------------
test_tape_order_code_and_data:
    SEEK 0
    SET "data-before"
    MOVE 1
    SET (SET "executed-from-cell-1" ; PRINT)
    MOVE 1
    SET ["data-after", 3]

    BACK 1
    TYPE
    PRINT             # → code
    SET (SET "executed-from-cell-1" ; PRINT)

    BACK 1
    PRINT             # → data-before

    MOVE 2
    PRINT             # → [data-after,3]

    SEEK 1
    EXEC              # → executed-from-cell-1
    RET

# ---- Inject a Code value through argument cells and CALL from inside it -----
test_code_injection_with_call:
    SEEK 0
    SET (SETARG 0 "from injected code" ; CALL injected_printer)
    MOVE 2
    SET "sentinel-data"
    BACK 2
    SETARG 0          # pass current Code cell as argument
    CALL run_injected_code
    MOVE 2
    PRINT             # → sentinel-data
    RET

run_injected_code:
    GETARG 0
    EXEC
    RET

injected_printer:
    GETARG 0
    PRINT
    RET

# ---- Self modification across cells before execution -----------------------
test_self_modify_across_cells:
    SEEK 0
    SET (SET "original" ; PRINT ; MOVE 1 ; SET "code-finished")
    MOVE 1
    SET ["SET", "patched"]
    MOVE 1
    SET ["PRINT"]
    BACK 2
    CODESET 0 1       # replace SET "original" with SET "patched"
    CODEAPPEND 2      # append one more PRINT instruction from cell 2
    EXEC              # → patched, code-finished
    BACK 1
    PRINT             # → patched
    MOVE 1
    PRINT             # → code-finished
    RET

# ---- Assembly-level exception handling over executable tape cells ----------
test_try_catch_code_block:
    SEEK 0
    SET (SET 10 ; DIV 0 ; SET "unreachable")
    MOVE 1
    SET (PRINTJ ; SET "recovered from symbolic error" ; PRINT)
    BACK 1
    TRY 1             # catch block sees error map in current cell
    RET

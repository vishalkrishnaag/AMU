# Test: tape-based loop helpers from stdlib
# Run: ./intense.out examples/test_stdlib_loop.in10s main 4

IMPORT ../stdlib.intense

def main
TAPE 5
SEEK 0
SET 3
SETARG 0 5
SETARG 1 (SEEK 0 ; PRINT ; SUB 1)
CALL tape_loop           # expected: 3 2 1
TAPE 5
SEEK 0
PRINT                    # expected: 0

TAPE 6
SEEK 0
SET 2
SETARG 0 6
SETARG 1 (SEEK 1 ; SET @0 ; MUL 10 ; PRINT ; SEEK 0 ; SUB 1)
CALL loop                # expected: 20 10
RET
end

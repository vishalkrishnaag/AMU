# Test: ValueKind enum, TYPE instruction, CAST instruction
# Run: ./intense.out examples/test_types.intense main

main:
    # ---- TYPE reports the right name for each ValueKind ----
    SET 42
    TYPE
    PRINT          # → int

    MOVE 1
    SET 3.14
    TYPE
    PRINT          # → float

    MOVE 1
    SET true
    TYPE
    PRINT          # → bool

    MOVE 1
    SET "hello"
    TYPE
    PRINT          # → str

    MOVE 1
    SET 'Z'
    TYPE
    PRINT          # → char

    MOVE 1
    SET [1,2,3]
    TYPE
    PRINT          # → list

    MOVE 1
    SET {"x":1}
    TYPE
    PRINT          # → map

    MOVE 1
    SET null
    TYPE
    PRINT          # → nil

    # ---- CAST: int → float ----
    MOVE 1
    SET 7
    CAST float
    TYPE
    PRINT          # → float   then  7

    MOVE 1
    SET 7
    CAST float
    PRINT          # → 7

    # ---- CAST: float → int (truncates) ----
    MOVE 1
    SET 9.9
    CAST int
    PRINT          # → 9

    # ---- CAST: int → bool ----
    MOVE 1
    SET 0
    CAST bool
    PRINT          # → false

    MOVE 1
    SET 42
    CAST bool
    PRINT          # → true

    # ---- CAST: str → int ----
    MOVE 1
    SET "123"
    CAST int
    PRINT          # → 123

    # ---- CAST: int → str ----
    MOVE 1
    SET 999
    CAST str
    TYPE
    PRINT          # → str   then  999

    # ---- CAST: str first char → char ----
    MOVE 1
    SET "Alpha"
    CAST char
    PRINT          # → A

    RET

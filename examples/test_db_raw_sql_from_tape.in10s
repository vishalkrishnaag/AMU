# DB raw SQL from tape cells.
#
# Edit the connection string below to match your local PostgreSQL role/database.
# This test uses DBQUERY with SQL stored in a tape cell.
#
# Run:
#   ./intense.out examples/test_db_raw_sql_from_tape.in10s main 4

main:
    SEEK 0
    SET "host=localhost port=5432 dbname=intense user=intense password=intense"
    DBCONNECT @0
    PRINTJ

    SEEK 1
    SET "SELECT 1 AS one, 'poet' AS name"
    DBQUERY @1
    PRINTJ

    DBCLOSE
    PRINTJ
    RET

# Test: min and max functions from stdlib
# Run: ./intense.out examples/test_stdlib_minmax.intense main

IMPORT ../stdlib.intense

main:
    CALL test_min
    CALL test_max
    RET

test_min:
    SETARG 0 10
    SETARG 1 5
    CALL min
    PRINT             # → 5

    SETARG 0 3
    SETARG 1 8
    CALL min
    PRINT             # → 3

    SETARG 0 -5
    SETARG 1 -2
    CALL min
    PRINT             # → -5
    RET

test_max:
    SETARG 0 10
    SETARG 1 5
    CALL max
    PRINT             # → 10

    SETARG 0 3
    SETARG 1 8
    CALL max
    PRINT             # → 8

    SETARG 0 -5
    SETARG 1 -2
    CALL max
    PRINT             # → -2
    RET

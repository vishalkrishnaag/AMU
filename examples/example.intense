main:
    call test_linearreg
    TYPE
    PRINT
 RET


# ---- LINEARREG + PREDICT: y=2x fits perfectly ----
test_linearreg:
    # Fit on points where y=2x: (1,2),(2,4),(3,6),(4,8),(5,10)
    SET [[1,2],[2,4],[3,6],[4,8],[5,10]]
    LINEARREG
    PRINT          # → [2,0]  (slope=2, intercept=0)

    # Predict y for x=7 using model stored at cell 0
    MOVE 1
    SET 7.0
    PREDICT 0
    PRINT          # → 14
    RET
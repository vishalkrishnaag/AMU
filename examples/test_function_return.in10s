main:
    CALL compute_value
    # After CALL, tape should have the value set by compute_value
    PRINT  # Should print the computed value
    # Now pass it to another function using SETARG
    SETARG 0  # Uses current cell (the returned value)
    CALL use_value
    RET

compute_value:
    SET 42
    RET

use_value:
    GETARG 0
    PRINT  # Should print 42
    RET
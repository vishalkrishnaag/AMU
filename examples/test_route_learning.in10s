# Test: automatic evidence-based route learning with a model-defined router.
# Run: ./intense.out examples/test_route_learning.in10s main 4

IMPORT ./navigation_route_model.in10s

def main
CALL seed_navigation_route_model

TAPE 0
SEEK 0
SET "i have arrived a wrong location using google map in walk mode"

# Observe the statement into a named memory tape, creating resource cells and
# evidence links without treating the statement as a question.
ROUTE_OBSERVE @0 route_memory
JSONGET "status"
PRINT

SEEK 1
SET "i have arrived a wrong location using google map in walk mode"
ROUTE_CONTEXT @1 route_memory 2
JSONGET "mode"
PRINT

# Runtime cache tools: active model memories are heated; cold memories can be
# packed as scalar text for DB persistence by existing DB_TAPE_* instructions.
ROUTE_USE google_map route_memory 2
ROUTE_CACHE route_memory 2 0.25
JSONGET "hot"
PRINTJ
ROUTE_PACK route_memory cold
SETARG 0
TYPE
PRINT
SEEK 2
GETARG 0
ROUTE_UNPACK @2 route_archive
JSONGET "status"
PRINT
RET
end

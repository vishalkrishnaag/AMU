# Test: routed tape.cell addressing and plastic inter-cell links.
# Run: ./intense.out examples/test_tape_routing.in10s main 4

def main
TAPE 1
TAPE_NAME memory_1alpha
SEEK 2
SET "map"
SEEK 3
SET "google map"
SEEK 4
SET "walk mode"

# Existing primitive read/write opcodes now understand routed addresses.
TAPE 0
SEEK 0
TGET memory_1alpha.2
PRINT

SET "wrong location"
TPUT memory_1alpha.5
TGET @memory_1alpha.5
PRINT

# SET can dereference routed resource locators too.
SET @memory_1alpha.3
PRINT

# Explicit route aliases are useful when the code is about routing itself.
RSET 2.7 "destination intent"
RGET 2.7
PRINT

# Links live on tape cells, so traversals can prefer stronger associations.
RLINK memory_1alpha.3 memory_1alpha.2 is_a 0.9
RLINK memory_1alpha.4 memory_1alpha.3 mode_of 0.8
RTOUCH memory_1alpha.4 memory_1alpha.3 mode_of 0.2
RFOLLOW memory_1alpha.4 mode_of
PRINTJ

RINFO memory_1alpha.3
PRINTJ
RET
end

# Test: def/end function syntax
# Run: ./intense.out examples/test_def_syntax.in10s main 4

def main
CALL greet
CALL countdown
CALL branch_return
RET
end

def greet
SET "hello from def"
PRINT
RET
end

def countdown
SET 3
$loop:
PRINT
SUB 1
JMPIF $loop
RET
end

def branch_return
SET 1
JMPIF $truthy
SET "false branch"
PRINT
RET
$truthy:
SET "true branch"
PRINT
RET
end

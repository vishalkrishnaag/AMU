main:
    CALL test_grammar
    CALL test_context
    CALL test_logic
    CALL test_fuzzy
    CALL test_prob
    RET

test_grammar:
    SET "this is a test sentence"
    NLPGRAMMAR
    PRINTJ
    RET

test_context:
    SET "The quick brown fox jumps over the lazy dog"
    NLPCONTEXT
    PRINTJ
    RET

test_logic:
    SET "if it rains then the ground is wet"
    NLPLOGIC "contrapositive"
    PRINTJ
    SET "if it rains then the ground is wet"
    NLPLOGIC "converse"
    PRINTJ
    RET

test_fuzzy:
    SET "This is a great and wonderful product"
    NLPFUZZY 0.5
    PRINTJ
    RET

test_prob:
    SET "the cat sat on the mat the cat is fat"
    NLPPROB "token"
    PRINTJ
    RET
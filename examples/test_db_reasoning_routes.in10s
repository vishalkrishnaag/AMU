# Test: extracted relation -> reusable route lookup -> graph memory lookup
#
# This demonstrates reusable route selection without hard-coding the route in
# Poet source. The input is parsed by NLPRELATIONS, then the extracted intent,
# subject, and relation are used to query Postgres.
#
# Run:
#   ./intense.out examples/test_db_reasoning_routes.in10s main 4

main:
    SET "host=localhost port=5432 dbname=AMU user=postgres password=postgres"
    DBCONNECT
    PRINTJ

    READFILE "training/common_memory/postgres_schema.sql"
    DBEXEC
    PRINTJ

    DBEXEC "INSERT INTO logic_nodes (node_key, kind, payload, confidence) VALUES ('cat','entity','{\"name\":\"cat\"}'::jsonb,0.95), ('count_4','quantity','{\"value\":\"4\",\"number\":4}'::jsonb,0.98) ON CONFLICT (node_key) DO NOTHING"
    PRINTJ
    DBEXEC "INSERT INTO logic_edges (source_key, relation, target_key, logic_weight, evidence, generated_logic) VALUES ('cat','legs_count','count_4','{\"state\":\"confirmed\",\"support\":\"route_seed\",\"scope\":\"normal_case\"}'::jsonb,'{\"text\":\"cat has 4 legs\"}'::jsonb,'SET 4') ON CONFLICT (source_key, relation, target_key) DO UPDATE SET logic_weight = EXCLUDED.logic_weight, evidence = EXCLUDED.evidence, generated_logic = EXCLUDED.generated_logic, validity = 'active', updated_at = now()"
    PRINTJ

    SEEK 0
    SET "how many legs does a cat have"
    NLPRELATIONS
    PRINTJ
    TAPEWRITE 0 1

    JSONGET "primary"
    TAPEWRITE 0 2

    JSONGET "intent"
    DBLITERAL
    TAPEWRITE 0 3

    SEEK 4
    SET "intent = "
    CONCAT @3
    CONCAT " AND status = 'active'"
    DBSELECT "reasoning_routes" @4
    PRINTJ

    SEEK 2
    JSONGET "subject"
    DBLITERAL
    TAPEWRITE 0 5

    SEEK 2
    TAPEREAD 0 2
    JSONGET "relation"
    DBLITERAL
    TAPEWRITE 0 6

    SEEK 7
    SET "source_key = "
    CONCAT @5
    CONCAT " AND relation = "
    CONCAT @6
    CONCAT " AND validity = 'active'"
    DBSELECT "logic_edges" @7
    PRINTJ

    DBCLOSE
    PRINTJ
    RET

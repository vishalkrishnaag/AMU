# argmin(list): find index of minimum element
# Args: SETARG 0 list
# Output: current cell = index of min element
argmin:
    GETARG 0
    SET 0
    RET

# ============================================================================
# UTILITY OPERATIONS
# ============================================================================

# list_length(list): get number of elements in list
# Args: SETARG 0 list
# Output: current cell = length
list_length:
    GETARG 0
    LEN
    RET

# print_vector(v_idx): print a vector/list nicely
# Args: SETARG 0 v cell index
# Output: prints the vector
print_vector:
    GETARG 0
    PRINTJ
    RET


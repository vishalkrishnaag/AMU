# Test: non-negative tape indexes grow dynamically.
# Run: ./intense.out test_cases/test_dynamic_tapes.in10s main 4

main:
    TAPE 12
    SEEK 3
    SET "deep-thought"

    TAPE 0
    SEEK 0
    TAPEREAD 12 3
    PRINT

    SET "runtime-tape"
    TAPEWRITE 25 9

    TAPE 25
    SEEK 9
    PRINT

    PRINT_TAPE 25
    RET

# Test: tape-native Postgres memory opcodes.
#
# Edit the connection string below for your local database.
# Run: ./intense.out test_cases/test_db_tape_memory.in10s main 4

main:
    SET "host=localhost port=5432 dbname=AMU user=postgres password=postgres"
    DBCONNECT

    READFILE "training/common_memory/postgres_schema.sql"
    DBEXEC

    DB_TAPE_OPEN "test_case_memory" "test"

    TAPE 7
    SEEK 0
    SET "problem:cat_legs"
    DB_TAPE_INPUT "test_case_memory"

    SEEK 1
    SET 4
    DB_TAPE_INPUT "test_case_memory"

    DB_TAPE_EVENT "test_case_memory" "seed" "cat legs answer stored"

    TAPE 0
    SEEK 0
    DB_TAPE_OUTPUT "test_case_memory" 7 1
    PRINT

    DBCLOSE
    RET

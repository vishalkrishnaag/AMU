# Test: load only required persisted tapes from Postgres.
#
# Edit the connection string below for your local database.
# Run: ./intense.out test_cases/test_db_tape_load_required_tapes.in10s main 4

main:
    SET "host=localhost port=5432 dbname=AMU user=postgres password=postgres"
    DBCONNECT

    READFILE "training/common_memory/postgres_schema.sql"
    DBEXEC

    DB_TAPE_OPEN "required_tape_memory" "test"

    TAPE 2
    SEEK 0
    SET "observation"
    DB_TAPE_INPUT "required_tape_memory"

    TAPE 8
    SEEK 4
    SET "root-cause-step"
    DB_TAPE_INPUT "required_tape_memory"

    TAPE 2
    CLEAR_TAPE
    TAPE 8
    CLEAR_TAPE

    DB_TAPE_LOAD "required_tape_memory" 8
    TAPE 8
    SEEK 4
    PRINT

    DBCLOSE
    RET
